# -----------------------------------------------------------
# epikur-systemd-controller — environment configuration
# -----------------------------------------------------------
# Copy this file to .env and fill in the values for your
# deployment.  The .env file must NEVER be committed to Git
# (it is already listed in .gitignore).
# -----------------------------------------------------------

# Comma-separated list of systemd service names that the
# dashboard is allowed to display and restart.
# Only services listed here will be accepted; any request
# for an unlisted service is rejected with HTTP 403.
#
# Example (single service):
#   ALLOWED_SERVICES=epikur.service
#
# Example (multiple services):
#   ALLOWED_SERVICES=epikur.service,nginx.service,postgresql.service
ALLOWED_SERVICES=epikur.service

# Gunicorn bind address and port.
# FLASK_HOST defaults to 0.0.0.0 in the systemd unit file.
# Set FLASK_HOST=127.0.0.1 here if you add a reverse proxy.
#FLASK_HOST=0.0.0.0
#FLASK_PORT=5000
