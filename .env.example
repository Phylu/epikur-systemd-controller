# -----------------------------------------------------------
# epikur-systemd-controller — environment configuration
# -----------------------------------------------------------
# Copy this file to .env and fill in the values for your
# deployment.  The .env file must NEVER be committed to Git
# (it is already listed in .gitignore).
# -----------------------------------------------------------

# Comma-separated list of systemd service names that the
# dashboard is allowed to display and restart.
# Only services listed here will be accepted; any request
# for an unlisted service is rejected with HTTP 403.
#
# Example (single service):
#   ALLOWED_SERVICES=epikur.service
#
# Example (multiple services):
#   ALLOWED_SERVICES=epikur.service,nginx.service,postgresql.service
ALLOWED_SERVICES=epikur.service

# [Required] Secret key for Flask session management and CSRF protection.
# Must be a strong random value and remain consistent across all Gunicorn workers
# so that sessions and CSRF tokens stay valid across restarts and between workers.
# Generate a key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=CHANGE_ME_OR_GENERATE_WITH_COMMAND_BELOW

# Gunicorn bind address and port.
# 127.0.0.1 is the safe default for local-only operation.
# Override FLASK_HOST to an internal IP address when external access is required,
# and ensure the appropriate firewall rules are in place before doing so.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# [Required] Basic authentication credentials for the dashboard.
# Set both to strong, unique values before starting the application.
# CAUTION: Never deploy with the placeholder values below.
BASIC_AUTH_USERNAME=CHANGE_ME
BASIC_AUTH_PASSWORD=CHANGE_ME
